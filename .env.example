# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key

# Frontend admin allowlist (emails separes par des virgules)
VITE_ADMIN_EMAILS=contact@socaftan.fr,sara.ltr@outlook.fr

# Supabase Edge Functions (pour les fonctions Stripe)
# Ces variables sont configurées dans Supabase Dashboard > Edge Functions > Secrets
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SITE_URL=https://socaftan.com
# ADMIN_EMAILS=contact@socaftan.fr,sara.ltr@outlook.fr

# Formulaire de contact (secrets Supabase Edge Functions)
# RESEND_API_KEY=re_xxxxxxxxx
# CONTACT_TO_EMAIL=contact@socaftan.fr
# CONTACT_FROM_EMAIL=SO Caftan <contact@socaftan.fr>
